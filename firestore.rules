rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // User Profiles
    match /users/{userId} {
      // Users can read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Admins can read all profiles
      allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
      
      // Users can create/update their profile, BUT they cannot make themselves admin
      allow create: if request.auth != null && request.auth.uid == userId 
                    && request.resource.data.isAdmin == false;
                    
      allow update: if request.auth != null && request.auth.uid == userId 
                    && request.resource.data.isAdmin == resource.data.isAdmin; // Can't change admin status
                    
      // Only admins can delete users or change admin status
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Saved Brands Subcollection
    match /users/{userId}/savedBrands/{brandId} {
      // Users can read/write their own saved brands
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Admins can read all saved brands
      allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
      
      // Rate limiting / abuse prevention for brand saving:
      // (Requires Cloud Functions for strict enforcement, but we can do basic data validation here)
      allow create, update: if request.resource.data.name is string 
                            && request.resource.data.name.size() > 0
                            && request.resource.data.name.size() < 100;
    }
    
    // App Settings / Config
    match /settings/{docId} {
      allow read: if true; // Public configuration
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
